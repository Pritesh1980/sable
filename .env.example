# Backend selection. 'local' (default) keeps everything offline in the browser —
# no account needed, used for dev and tests. 'supabase' enables real accounts +
# cross-device sync. 'aws' is a reserved future slot.
VITE_BACKEND=local

# The single owner account that keeps the curated DEFAULT_ARTISTS seed; every
# other account starts empty.
VITE_OWNER_EMAIL=owner@example.com

# Required when VITE_BACKEND=supabase. The anon key is publishable, but Row Level
# Security MUST be enabled on the collections table and the storage bucket before
# any real data lands, or rows/objects are world-readable.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
